# Copie este arquivo para .env e preencha com suas chaves do Firebase
# NUNCA commite o arquivo .env no GitHub
# NUNCA coloque valores reais no replit.md ou em qualquer arquivo versionado

VITE_FIREBASE_API_KEY=sua_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu_projeto_id
VITE_FIREBASE_STORAGE_BUCKET=seu_projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_sender_id
VITE_FIREBASE_APP_ID=seu_app_id
VITE_FIREBASE_MEASUREMENT_ID=seu_measurement_id

# App Check debug token — registrado no Firebase Console > App Check > Debug Tokens
# Usado SOMENTE em desenvolvimento (nunca vai para o build de produção)
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=seu_debug_token_aqui

VITE_CLOUDINARY_CLOUD_NAME=seu_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=seu_preset
VITE_RECAPTCHA_SITE_KEY=sua_site_key
